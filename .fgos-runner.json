{
  "executor": {
    "command": "claude",
    "args": ["-p", "{prompt}", "--model", "{model}", "--permission-mode", "acceptEdits", "--allowedTools", "Bash(git add:*),Bash(git commit:*)"]
  },
  "models": {
    "light": "haiku",
    "standard": "sonnet",
    "heavy": "opus"
  },
  "timeoutMs": 300000
}
